[MASTER]
ignore=.venv,node_modules,__pycache__,vendor
ignore-paths=.*/.venv/.*,.*/__pycache__/.*
init-hook=
    import sys
    sys.path.insert(0, 'mtg-sim/sim')
    sys.path.insert(0, 'mtg-sim/classifier')
    sys.path.insert(0, 'mtg-sim/.venv/lib/python3.11/site-packages')

[FORMAT]
max-line-length=100
max-module-lines=1200

[DESIGN]
# Dataclasses legitimately have many fields; raise threshold to accommodate them.
max-attributes=12
# Game simulation loops require more local variables and statements than typical code.
max-locals=20
max-statements=60
# Simulation methods require more positional arguments than typical helpers.
max-args=6
max-positional-arguments=6
