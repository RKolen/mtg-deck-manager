# Spreadsheet source files (personal data)
*.xlsx
*.xls
*.ods

# Planning notes (local only)
plan.md

# ============================================================
# DDEV
# ============================================================
.ddev/config.local.yaml
.ddev/.gitignore

# ============================================================
# Drupal
# ============================================================
drupal/vendor/
drupal/web/sites/default/files/
drupal/web/sites/default/settings.local.php
drupal/web/sites/simpletest/

# Composer-generated lock artifacts (keep composer.lock in git)
drupal/web/core/
drupal/web/modules/contrib/
drupal/web/themes/contrib/
drupal/web/profiles/contrib/
drupal/web/libraries/

# Scryfall bulk data (~300 MB, re-downloaded by sync module)
drupal/web/modules/custom/mtg_scryfall_sync/data/*.json

# Drupal private files / temp
drupal/private/
drupal/scripts/
drupal/tmp/

