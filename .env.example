# MTG Deck Manager — single source of truth for host service ports and shared config.
# Copy to .env in this directory (repo root). Never commit .env.
#
# Also set mtg-app/.env.development (Gatsby only — not read from here):
#   GATSBY_SIM_URL=   # port must match SIM_PORT below
#
# DDEV: MTG_SIM_SERVICE_URL in drupal/.ddev/config.yaml must use the same port.

# --- Frontend / Drupal URLs ---
GATSBY_PORT=
DRUPAL_URL=
MTGGOLDFISH_BASE_URL=

# --- Host AI (Ollama + sidecar) ---
OLLAMA_PORT=
OLLAMA_MODEL=
# OLLAMA_THINK=false recommended for pilot-pick (avoids chain-of-thought in logs).
# Set true only for qwen3-style models that need thinking for quality.
OLLAMA_THINK=false
# Pilot-pick token budget when thinking: num_predict = THINK_BUDGET + RESPONSE_BUDGET (or set PILOT_NUM_PREDICT).
OLLAMA_PILOT_THINK_BUDGET=
OLLAMA_PILOT_RESPONSE_BUDGET=
OLLAMA_PILOT_NUM_PREDICT=
OLLAMA_PILOT_REASONING_MAX=
# Set to at least 8192 when pilot prompts exceed ~2000 tokens (~8000 chars).
# Without this Ollama uses its default (often 2048) and truncates the prompt.
OLLAMA_NUM_CTX=
SIDECAR_PORT=

# --- Infrastructure ---
# DDEV-internal Milvus gRPC port (Drupal uses milvus:19530 — not on host localhost).
MILVUS_PORT=

# --- Python sim service (mtg-sim/sim) ---
SIM_PORT=
SIM_HOST=
CORS_ORIGINS=

# --- Drupal API credentials (used by sim + classifier) ---
DRUPAL_USER=
DRUPAL_PASS=

# --- Forge (optional — omit FORGE_JAR for mock sim mode) ---
FORGE_JAR=
FORGE_JAVA=java
# Seconds Forge waits for each pilot-pick HTTP response. Raise for large models (27B+).
FORGE_PILOT_TIMEOUT=120

# Caveman-style pilot prompt compression (field_notes + archetype priors)
# rules = local deterministic (default). llm = one-time Ollama compress (think=false).
# off = send full field_notes. Do NOT use llm with OLLAMA_THINK=true.
CAVEMAN_PILOT=rules
CAVEMAN_PILOT_MIN_CHARS=120
CAVEMAN_PILOT_MIN_SAVED=40
CAVEMAN_PILOT_MIN_RATIO=0.08
CAVEMAN_PILOT_PREVIEW_CHARS=600

# Chunk long sims (50/200) into multiple Forge runs; logs after each batch
SIM_BATCH_SIZE=5
