# MTG Deck Manager — single source of truth for host service ports and shared config.
# Copy to .env in this directory (repo root). Never commit .env.
#
# Also set mtg-app/.env.development (Gatsby only — not read from here):
#   GATSBY_SIM_URL=   # port must match SIM_PORT below
#
# DDEV: MTG_SIM_SERVICE_URL in drupal/.ddev/config.yaml must use the same port.

# --- Frontend / Drupal URLs ---
GATSBY_PORT=
DRUPAL_URL=
MTGGOLDFISH_BASE_URL=

# --- Host AI (Ollama + sidecar) ---
OLLAMA_PORT=
OLLAMA_MODEL=
SIDECAR_PORT=

# --- Infrastructure ---
# DDEV-internal Milvus gRPC port (Drupal uses milvus:19530 — not on host localhost).
MILVUS_PORT=

# --- Python sim service (mtg-sim/sim) ---
SIM_PORT=
SIM_HOST=
CORS_ORIGINS=

# --- Drupal API credentials (used by sim + classifier) ---
DRUPAL_USER=
DRUPAL_PASS=

# --- Forge (optional — omit FORGE_JAR for mock sim mode) ---
FORGE_JAR=
FORGE_JAVA=java
