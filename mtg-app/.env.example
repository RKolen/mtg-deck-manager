# Next.js environment. Copy to .env.local (never commit credentials).
#
# Drupal URL must match repo-root .env DRUPAL_URL.
# NEXT_PUBLIC_SIM_URL port must match repo-root .env SIM_PORT.
# NEXT_PUBLIC_CLASSIFIER_URL must match CLASSIFIER_HOST:CLASSIFIER_PORT in root .env
# (start.sh sets this automatically when the frontend env omits it).
# NEXT_PUBLIC_CLASSIFIER_URL must match repo-root .env CLASSIFIER_PORT.

NEXT_PUBLIC_DRUPAL_URL=
NEXT_PUBLIC_DRUPAL_USER=
NEXT_PUBLIC_DRUPAL_PASS=

NEXT_PUBLIC_SIM_URL=
NEXT_PUBLIC_CLASSIFIER_URL=

NODE_EXTRA_CA_CERTS=
