# Copy this file to .env.development (or .env.production) and fill in the values.
# Never commit a file that contains real credentials.

# Used by gatsby-source-drupal at build time.
DRUPAL_URL=
# Used by runtime API clients (browser bundle).
# Must match DRUPAL_URL above — the GATSBY_ prefix is required for
# Gatsby to inline the value into the client-side bundle.
GATSBY_DRUPAL_URL=
GATSBY_DRUPAL_USER=
GATSBY_DRUPAL_PASS=

GATSBY_CLASSIFIER_URL=

# Default: http://localhost:8002 (called server-side by Drupal, not client-side)
# Start with: cd mtg-sim/sim && uvicorn main:app --port 8002
# Set FORGE_JAR=... to enable real Forge; omit for mock mode.

# Trust the local mkcert CA for self-signed DDEV certificates.
# Only needed in development; remove for production.
NODE_EXTRA_CA_CERTS=
