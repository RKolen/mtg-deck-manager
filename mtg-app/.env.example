# Gatsby-only environment. Copy to .env.development (never commit credentials).
#
# Drupal URL must match repo-root .env DRUPAL_URL (with GATSBY_ prefix for runtime).
# GATSBY_SIM_URL port must match repo-root .env SIM_PORT.

SITE_URL=

DRUPAL_URL=
GATSBY_DRUPAL_URL=
GATSBY_DRUPAL_USER=
GATSBY_DRUPAL_PASS=

GATSBY_SIM_URL=
GATSBY_CLASSIFIER_URL=

NODE_EXTRA_CA_CERTS=
