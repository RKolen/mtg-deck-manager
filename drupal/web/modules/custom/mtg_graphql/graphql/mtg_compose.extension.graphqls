extend type Query {
  cards(
    page: Int
    limit: Int
    name: String
    colors: [String!]
    type: String
    maxCmc: Float
    titlePrefix: String
  ): CardPage!

  card(slug: String!): MtgCard

  cardsByName(name: String!): [MtgCard!]!

  deckCards(deckId: ID!): [DeckCard!]!

  deckCardsByNid(nid: Int!): [DeckCard!]!

  collectionCardByCardId(cardId: ID!): CollectionCard

  collectionValue: Float!

  pages: [Page!]!

  metaDecks(format: String!): [MetaDeck!]!

  simulationHistory(deckNid: Int!, limit: Int): [SimulationResult!]!

  cardSearch(
    q: String
    type: String
    oracleText: String
    legalIn: String
    cmcMin: Float
    cmcMax: Float
    colors: [String!]
    colorIdentity: [String!]
    manaProducer: Boolean
    rarity: String
    page: Int
    limit: Int
  ): CardSearchResult!
}

extend type Mutation {
  createDeck(title: String!, format: String!, notes: String): Deck!

  updateDeck(id: ID!, title: String, format: String, notes: String): Deck!

  deleteDeck(id: ID!): Boolean!

  upsertCollectionCard(
    cardId: ID!
    cardName: String!
    quantityOwned: Int!
    quantityFoil: Int
    existingId: ID
  ): CollectionCard!

  deckCardAdd(
    deckId: ID!
    cardId: ID!
    quantity: Int!
    isSideboard: Boolean!
  ): DeckCardSlot!

  deckCardUpdate(deckId: ID!, slotId: ID!, quantity: Int!): DeckCardSlot!

  deckCardRemove(deckId: ID!, slotId: ID!): Boolean!
}
