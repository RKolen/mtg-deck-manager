<?php

declare(strict_types=1);

/**
 * @file
 * Install, update, and uninstall functions for the MTG Card Suggestions module.
 */

use Drupal\Core\Entity\Entity\EntityFormDisplay;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\node\Entity\NodeType;
use Drupal\taxonomy\Entity\Term;
use Drupal\taxonomy\Entity\Vocabulary;

/**
 * Creates the meta_deck content type and its fields.
 *
 * Run via: ddev drush updb -y
 *
 * The meta_deck type stores canonical archetype decklists scraped from
 * MTGGoldfish. Each node represents one archetype in one format at a
 * point in time (field_fetched_at).
 */
function mtg_card_suggestions_update_10001(array &$sandbox): string {
  // ------------------------------------------------------------------
  // Content type
  // ------------------------------------------------------------------
  if (!NodeType::load('meta_deck')) {
    NodeType::create([
      'type'        => 'meta_deck',
      'name'        => 'Meta Deck',
      'description' => 'Canonical meta archetype decklist snapshot.',
    ])->save();
  }

  // ------------------------------------------------------------------
  // Field definitions
  // ------------------------------------------------------------------
  $fields = [
    [
      'name'        => 'field_format',
      'entity_type' => 'node',
      'type'        => 'string',
      'label'       => 'Format',
      'cardinality' => 1,
      'settings'    => ['max_length' => 32],
      'bundles'     => ['meta_deck'],
    ],
    [
      'name'        => 'field_meta_share',
      'entity_type' => 'node',
      'type'        => 'decimal',
      'label'       => 'Meta Share (%)',
      'cardinality' => 1,
      'settings'    => ['precision' => 5, 'scale' => 2],
      'bundles'     => ['meta_deck'],
    ],
    [
      'name'        => 'field_cards',
      'entity_type' => 'node',
      'type'        => 'text_long',
      'label'       => 'Cards (JSON)',
      'cardinality' => 1,
      'settings'    => [],
      'bundles'     => ['meta_deck'],
    ],
    [
      'name'        => 'field_archetype_tags',
      'entity_type' => 'node',
      'type'        => 'string',
      'label'       => 'Archetype Tags',
      'cardinality' => -1,
      'settings'    => ['max_length' => 32],
      'bundles'     => ['meta_deck'],
    ],
    [
      'name'        => 'field_fetched_at',
      'entity_type' => 'node',
      'type'        => 'datetime',
      'label'       => 'Fetched At',
      'cardinality' => 1,
      'settings'    => ['datetime_type' => 'datetime'],
      'bundles'     => ['meta_deck'],
    ],
    [
      'name'        => 'field_sideboard_guide',
      'entity_type' => 'node',
      'type'        => 'text_long',
      'label'       => 'Sideboard Guide',
      'cardinality' => 1,
      'settings'    => [],
      'bundles'     => ['meta_deck'],
    ],
    // field_key_cards is an entity reference to mtg_card nodes.
    // Created separately below because it needs handler_settings.
  ];

  $created = [];

  foreach ($fields as $def) {
    if (!FieldStorageConfig::loadByName($def['entity_type'], $def['name'])) {
      FieldStorageConfig::create([
        'field_name'  => $def['name'],
        'entity_type' => $def['entity_type'],
        'type'        => $def['type'],
        'cardinality' => $def['cardinality'],
        'settings'    => $def['settings'],
      ])->save();
    }

    foreach ($def['bundles'] as $bundle) {
      if (!FieldConfig::loadByName($def['entity_type'], $bundle, $def['name'])) {
        FieldConfig::create([
          'field_name'  => $def['name'],
          'entity_type' => $def['entity_type'],
          'bundle'      => $bundle,
          'label'       => $def['label'],
          'required'    => FALSE,
        ])->save();
        $created[] = $def['name'] . ' on ' . $bundle;
      }
    }
  }

  // Entity reference field for key cards (references mtg_card nodes).
  if (!FieldStorageConfig::loadByName('node', 'field_key_cards')) {
    FieldStorageConfig::create([
      'field_name'  => 'field_key_cards',
      'entity_type' => 'node',
      'type'        => 'entity_reference',
      'cardinality' => -1,
      'settings'    => ['target_type' => 'node'],
    ])->save();
  }
  if (!FieldConfig::loadByName('node', 'meta_deck', 'field_key_cards')) {
    FieldConfig::create([
      'field_name'  => 'field_key_cards',
      'entity_type' => 'node',
      'bundle'      => 'meta_deck',
      'label'       => 'Key Cards',
      'required'    => FALSE,
      'settings'    => [
        'handler'          => 'default:node',
        'handler_settings' => [
          'target_bundles' => ['mtg_card' => 'mtg_card'],
        ],
      ],
    ])->save();
    $created[] = 'field_key_cards on meta_deck';
  }

  return $created !== []
    ? 'Created: ' . implode(', ', $created)
    : 'meta_deck content type and all fields already exist.';
}

/**
 * Creates the simulation_result content type and its fields.
 *
 * Stores historical simulation runs for comparison across deck iterations.
 * Run via: ddev drush updb -y
 */
function mtg_card_suggestions_update_10002(array &$sandbox): string {
  if (!NodeType::load('simulation_result')) {
    NodeType::create([
      'type'        => 'simulation_result',
      'name'        => 'Simulation Result',
      'description' => 'Stored MTG game simulation outcome.',
    ])->save();
  }

  $fields = [
    ['name' => 'field_sim_player_deck_nid', 'type' => 'integer',   'label' => 'Player Deck NID',       'cardinality' => 1, 'settings' => []],
    ['name' => 'field_sim_opponent',        'type' => 'string',    'label' => 'Opponent Archetype',    'cardinality' => 1, 'settings' => ['max_length' => 128]],
    ['name' => 'field_sim_format',          'type' => 'string',    'label' => 'Format',                'cardinality' => 1, 'settings' => ['max_length' => 32]],
    ['name' => 'field_sim_games',           'type' => 'integer',   'label' => 'Games Played',          'cardinality' => 1, 'settings' => []],
    ['name' => 'field_sim_wins',            'type' => 'integer',   'label' => 'Wins',                  'cardinality' => 1, 'settings' => []],
    ['name' => 'field_sim_win_rate',        'type' => 'decimal',   'label' => 'Win Rate',              'cardinality' => 1, 'settings' => ['precision' => 5, 'scale' => 4]],
    ['name' => 'field_sim_result_json',     'type' => 'text_long', 'label' => 'Full Result JSON',      'cardinality' => 1, 'settings' => []],
  ];

  $created = [];
  foreach ($fields as $def) {
    if (!FieldStorageConfig::loadByName('node', $def['name'])) {
      FieldStorageConfig::create([
        'field_name'  => $def['name'],
        'entity_type' => 'node',
        'type'        => $def['type'],
        'cardinality' => $def['cardinality'],
        'settings'    => $def['settings'],
      ])->save();
    }
    if (!FieldConfig::loadByName('node', 'simulation_result', $def['name'])) {
      FieldConfig::create([
        'field_name'  => $def['name'],
        'entity_type' => 'node',
        'bundle'      => 'simulation_result',
        'label'       => $def['label'],
        'required'    => FALSE,
      ])->save();
      $created[] = $def['name'];
    }
  }

  return $created !== []
    ? 'Created simulation_result fields: ' . implode(', ', $created)
    : 'simulation_result fields already exist.';
}

/**
 * Creates the mtg_format taxonomy vocabulary, its goldfish-slug field, and
 * seeds the canonical format terms used by the meta-deck scraper.
 *
 * Run via: ddev drush updb -y
 *
 * Each term stores a field_goldfish_slug that maps the display name (e.g.
 * "Pioneer") to the MTGGoldfish metagame slug (e.g. "pioneer"). The scraper
 * reads these terms to build the correct URL and stores the term name in
 * field_format on meta_deck nodes.
 */
function mtg_card_suggestions_update_10003(array &$sandbox): string {
  $created = [];

  // ------------------------------------------------------------------
  // Vocabulary
  // ------------------------------------------------------------------
  if (!Vocabulary::load('mtg_format')) {
    Vocabulary::create([
      'vid'         => 'mtg_format',
      'name'        => 'MTG Format',
      'description' => 'Canonical MTG competitive formats used by the meta-deck scraper.',
    ])->save();
    $created[] = 'vocabulary mtg_format';
  }

  // ------------------------------------------------------------------
  // field_goldfish_slug on taxonomy_term (shared across all vocabs).
  // ------------------------------------------------------------------
  if (!FieldStorageConfig::loadByName('taxonomy_term', 'field_goldfish_slug')) {
    FieldStorageConfig::create([
      'field_name'  => 'field_goldfish_slug',
      'entity_type' => 'taxonomy_term',
      'type'        => 'string',
      'cardinality' => 1,
      'settings'    => ['max_length' => 64],
    ])->save();
  }
  if (!FieldConfig::loadByName('taxonomy_term', 'mtg_format', 'field_goldfish_slug')) {
    FieldConfig::create([
      'field_name'  => 'field_goldfish_slug',
      'entity_type' => 'taxonomy_term',
      'bundle'      => 'mtg_format',
      'label'       => 'MTGGoldfish Slug',
      'required'    => TRUE,
    ])->save();
    $created[] = 'field_goldfish_slug on mtg_format';
  }

  // ------------------------------------------------------------------
  // Seed terms — only create if they do not already exist.
  // ------------------------------------------------------------------
  $formats = [
    'Modern'      => 'modern',
    'Pioneer'     => 'pioneer',
    'Legacy'      => 'legacy',
    'Pauper'      => 'pauper',
    'Standard'    => 'standard',
    'Vintage'     => 'vintage',
    'Commander'   => 'commander',
  ];

  $storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');

  foreach ($formats as $name => $slug) {
    $existing = $storage->loadByProperties([
      'vid'  => 'mtg_format',
      'name' => $name,
    ]);
    if ($existing !== []) {
      continue;
    }
    Term::create([
      'vid'                 => 'mtg_format',
      'name'                => $name,
      'field_goldfish_slug' => $slug,
    ])->save();
    $created[] = 'term ' . $name;
  }

  return $created !== []
    ? 'Created: ' . implode(', ', $created)
    : 'mtg_format vocabulary and terms already exist.';
}

/**
 * Adds field_format_term (taxonomy reference) to deck and meta_deck nodes.
 *
 * Migrates all existing field_format string values to taxonomy term references
 * using the mtg_format vocabulary seeded in update_10003. The legacy
 * field_format string field is left in place but will no longer be written to.
 */
function mtg_card_suggestions_update_10004(array &$sandbox): string {
  $created = [];

  // ------------------------------------------------------------------
  // Field storage: entity_reference to taxonomy_term.
  // ------------------------------------------------------------------
  if (!FieldStorageConfig::loadByName('node', 'field_format_term')) {
    FieldStorageConfig::create([
      'field_name'  => 'field_format_term',
      'entity_type' => 'node',
      'type'        => 'entity_reference',
      'cardinality' => 1,
      'settings'    => ['target_type' => 'taxonomy_term'],
    ])->save();
    $created[] = 'field_format_term storage';
  }

  // ------------------------------------------------------------------
  // Attach to deck and meta_deck bundles.
  // ------------------------------------------------------------------
  foreach (['deck', 'meta_deck'] as $bundle) {
    if (!FieldConfig::loadByName('node', $bundle, 'field_format_term')) {
      FieldConfig::create([
        'field_name'  => 'field_format_term',
        'entity_type' => 'node',
        'bundle'      => $bundle,
        'label'       => 'Format',
        'required'    => FALSE,
        'settings'    => [
          'handler'          => 'default:taxonomy_term',
          'handler_settings' => [
            'target_bundles' => ['mtg_format' => 'mtg_format'],
          ],
        ],
      ])->save();
      $created[] = 'field_format_term on ' . $bundle;
    }

    // Add to default form display so editors can see it.
    $formDisplay = EntityFormDisplay::load('node.' . $bundle . '.default');
    if ($formDisplay !== NULL && !isset($formDisplay->get('content')['field_format_term'])) {
      $formDisplay->setComponent('field_format_term', [
        'type'   => 'options_select',
        'weight' => 5,
      ])->save();
      $created[] = 'form display for ' . $bundle;
    }
  }

  // ------------------------------------------------------------------
  // Migrate existing string values to taxonomy term references.
  // ------------------------------------------------------------------
  $termStorage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $nodeStorage = \Drupal::entityTypeManager()->getStorage('node');

  // Build a name → term ID lookup from the mtg_format vocabulary.
  $termMap = [];
  foreach ($termStorage->loadByProperties(['vid' => 'mtg_format']) as $term) {
    $termMap[$term->getName()] = (int) $term->id();
  }

  $nids = $nodeStorage->getQuery()
    ->condition('type', ['deck', 'meta_deck'], 'IN')
    ->accessCheck(FALSE)
    ->execute();

  $migrated = 0;
  $skipped  = 0;

  foreach (array_chunk($nids, 50) as $chunk) {
    foreach ($nodeStorage->loadMultiple($chunk) as $node) {
      $formatName = $node->get('field_format')->value;
      if (!is_string($formatName) || $formatName === '' || !isset($termMap[$formatName])) {
        $skipped++;
        continue;
      }
      $node->set('field_format_term', ['target_id' => $termMap[$formatName]]);
      $node->setNewRevision(FALSE);
      $node->save();
      $migrated++;
    }
  }

  $summary = "Migrated {$migrated} nodes to field_format_term; {$skipped} skipped (no matching term).";
  return $created !== []
    ? implode(', ', $created) . '. ' . $summary
    : $summary;
}
