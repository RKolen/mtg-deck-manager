[MASTER]
ignore=.venv,__pycache__
init-hook=
    import sys
    sys.path.insert(0, 'mtg-sim/sim')
    sys.path.insert(0, 'mtg-sim/classifier')

[FORMAT]
max-line-length=100
max-module-lines=1200

[DESIGN]
# Dataclasses and cast-announce structs carry many keyword flags.
max-attributes=20
max-branches=18
max-returns=8
# Game simulation loops require more local variables and statements than typical code.
max-locals=20
max-statements=60
# Simulation methods require more positional arguments than typical helpers.
max-args=7
max-positional-arguments=7
