# Copy to .env and fill in values before starting the Python services.
# Source with: set -a && source .env && set +a

# ============================================================
# Classifier service (mtg-sim/classifier/main.py)
# ============================================================
CLASSIFIER_HOST=
CLASSIFIER_PORT=

# ============================================================
# Simulation service (mtg-sim/sim/main.py)
# ============================================================
SIM_HOST=
SIM_PORT=

# ============================================================
# Forge bridge (required to enable real Forge mode in sim service)
# All three must be set; omit to run in mock mode.
# ============================================================
FORGE_JAR=
FORGE_HOST=
FORGE_PORT=

# ============================================================
# Drupal backend (shared by both services)
# ============================================================
DRUPAL_URL=
DRUPAL_USER=
DRUPAL_PASS=

# ============================================================
# Ollama (optional — enables LLM board evaluation and key moments)
# ============================================================
OLLAMA_URL=
OLLAMA_MODEL=
